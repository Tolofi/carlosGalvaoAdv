---
const passos = [
  {
    num: "01",
    title: "Primeiro Contato",
    desc: "Envie uma mensagem pelo WhatsApp com um breve relato. Se tiver o número do processo, inclua."
  },
  {
    num: "02",
    title: "Triagem",
    desc: "Seu caso é analisado e você recebe as primeiras orientações sobre o que fazer agora."
  },
  {
    num: "03",
    title: "Consulta",
    desc: "Reunião por videochamada ou presencial para aprofundar o caso e apresentar a estratégia."
  },
  {
    num: "04",
    title: "Proposta",
    desc: "Você recebe a estratégia de defesa, os cenários possíveis e a proposta de honorários."
  },
  {
    num: "05",
    title: "Contrato",
    desc: "Assinado o contrato, você entra em canal exclusivo com atualizações em cada movimentação."
  },
  {
    num: "06",
    title: "Acompanhamento",
    desc: "Presença real em todas as audiências e atualização direta a cada etapa do processo."
  }
];
---

<section id="processo" class="py-24 bg-bg relative overflow-hidden">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-20 fade-up">
      <h2 class="font-playfair text-4xl sm:text-5xl font-bold text-white mb-4">
        Como funciona a sua <span class="text-gold italic">defesa</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">Um método claro e transparente para que você saiba exatamente o que esperar em cada etapa.</p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Center Line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-[2px] bg-gradient-to-b from-gold/5 via-gold/30 to-gold/5 -translate-x-1/2"></div>
      
      <div class="space-y-12">
        {passos.map((passo, index) => (
          <div class="fade-up relative flex flex-col md:flex-row items-start md:items-center justify-between group">
            
            <!-- Left Side (Empty on odds, content on evens in desktop) -->
            <div class={`w-full md:w-[45%] pl-12 md:pl-0 ${index % 2 !== 0 ? 'md:order-3 md:text-left' : 'md:order-1 md:text-right'}`}>
              <div class="bg-bg-card p-6 rounded-lg border border-white/5 group-hover:border-gold/30 transition-colors shadow-lg relative">
                <h3 class="text-xl font-bold text-white font-playfair mb-2">{passo.title}</h3>
                <p class="text-gray-400 text-sm leading-relaxed">{passo.desc}</p>
                
                <!-- Desktop Arrow connector -->
                <div class={`hidden md:block absolute top-1/2 -translate-y-1/2 w-4 h-4 bg-bg-card border-t border-r border-white/5 group-hover:border-gold/30 transition-colors transform ${index % 2 !== 0 ? '-left-2 -rotate-135' : '-right-2 rotate-45'}`}></div>
              </div>
            </div>
            
            <!-- Center Node -->
            <div class="absolute left-4 md:left-1/2 md:order-2 transform -translate-x-1/2 flex items-center justify-center w-8 h-8 rounded-full bg-bg border-2 border-gold text-gold font-bold text-xs z-10 shadow-[0_0_10px_rgba(201,168,76,0.3)] group-hover:scale-110 group-hover:bg-gold group-hover:text-bg transition-all duration-300 mt-5 md:mt-0">
              {passo.num}
            </div>
            
            <!-- Right Side (Spacer) -->
            <div class={`w-full md:w-[45%] hidden md:block ${index % 2 !== 0 ? 'md:order-1' : 'md:order-3'}`}></div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
