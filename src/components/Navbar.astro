---
const whatsappLink =
  "https://wa.me/5531991979373?text=Olá%2C%20vim%20pelo%20site%20e%20gostaria%20de%20falar%20com%20o%20Dr.%20Carlos%20Galvão.";
---

<header
  id="navbar"
  class="fixed top-0 w-full z-50 transition-all duration-300 border-b border-transparent bg-transparent"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <div class="flex flex-row">
        <a href="#" class="flex items-center gap-3 group">
          <span
            class="flex flex-col font-playfair text-xl font-bold tracking-wide text-white leading-tight"
          >
            Carlos Galvão
            <span class="text-gold text-lg font-medium tracking-normal"
              >Advocacia Criminal</span
            >
          </span>
        </a>
      </div>

      <!-- Desktop Menu -->
      <nav class="hidden md:block">
        <ul class="flex space-x-8 text-sm font-medium text-gray-300">
          <li>
            <a href="#sobre" class="hover:text-gold transition-colors">Sobre</a>
          </li>
          <li>
            <a href="#servicos" class="hover:text-gold transition-colors"
              >Serviços</a>
          </li>
          <li>
            <a href="#processo" class="hover:text-gold transition-colors"
              >Processo</a>
          </li>
          <li>
            <a href="#faq" class="hover:text-gold transition-colors">Dúvidas</a>
          </li>
          <li>
            <a href="#contato" class="hover:text-gold transition-colors"
              >Contato</a>
          </li>
        </ul>
      </nav>

      <!-- CTA -->
      <div class="hidden md:block">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-gold hover:bg-gold-light text-bg font-semibold py-2.5 px-6 rounded transition-all duration-300 shadow-[0_0_15px_rgba(201,168,76,0.3)] hover:shadow-[0_0_25px_rgba(201,168,76,0.5)]"
        >
          Falar agora
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button
          id="mobile-menu-btn"
          class="text-white hover:text-gold focus:outline-none p-2"
          aria-label="Menu"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              id="menu-icon"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-bg-card border-b border-gold/20 absolute w-full transition-all duration-300 origin-top opacity-0 scale-y-0"
  >
    <div class="px-4 pt-2 pb-6 space-y-1">
      <a
        href="#sobre"
        class="mobile-link block px-3 py-3 text-base font-medium text-gray-300 hover:text-gold hover:bg-white/5 rounded-md"
        >Sobre</a
      >
      <a
        href="#servicos"
        class="mobile-link block px-3 py-3 text-base font-medium text-gray-300 hover:text-gold hover:bg-white/5 rounded-md"
        >Serviços</a
      >
      <a
        href="#processo"
        class="mobile-link block px-3 py-3 text-base font-medium text-gray-300 hover:text-gold hover:bg-white/5 rounded-md"
        >Processo</a
      >
      <a
        href="#faq"
        class="mobile-link block px-3 py-3 text-base font-medium text-gray-300 hover:text-gold hover:bg-white/5 rounded-md"
        >Dúvidas</a
      >
      <a
        href="#contato"
        class="mobile-link block px-3 py-3 text-base font-medium text-gray-300 hover:text-gold hover:bg-white/5 rounded-md"
        >Contato</a
      >
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full text-center mt-4 bg-gold text-bg font-semibold py-3 rounded"
        >Falar agora</a
      >
    </div>
  </div>
</header>

<!-- Observer pixel to detect scrolling -->
<div
  id="nav-observer"
  class="absolute top-0 h-[1px] w-full pointer-events-none"
>
</div>

<script>
  // Navbar scroll effect
  const nav = document.getElementById("navbar");
  const observerPixel = document.getElementById("nav-observer");

  if (nav && observerPixel) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          nav.classList.add(
            "bg-bg/90",
            "backdrop-blur-md",
            "border-gold/30",
            "shadow-lg",
          );
          nav.classList.remove("bg-transparent", "border-transparent");
        } else {
          nav.classList.remove(
            "bg-bg/90",
            "backdrop-blur-md",
            "border-gold/30",
            "shadow-lg",
          );
          nav.classList.add("bg-transparent", "border-transparent");
        }
      },
      { threshold: [1] },
    );

    observer.observe(observerPixel);
  }

  // Mobile menu toggle
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const icon = document.getElementById("menu-icon");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  let isOpen = false;

  const toggleMenu = () => {
    isOpen = !isOpen;
    if (isOpen) {
      menu?.classList.remove("hidden");
      // small delay to allow display:block to apply before animation
      setTimeout(() => {
        menu?.classList.remove("opacity-0", "scale-y-0");
        menu?.classList.add("opacity-100", "scale-y-100");
      }, 10);
      icon?.setAttribute("d", "M6 18L18 6M6 6l12 12"); // X icon
    } else {
      menu?.classList.remove("opacity-100", "scale-y-100");
      menu?.classList.add("opacity-0", "scale-y-0");
      setTimeout(() => {
        menu?.classList.add("hidden");
      }, 300);
      icon?.setAttribute("d", "M4 6h16M4 12h16M4 18h16"); // Hamburger icon
    }
  };

  btn?.addEventListener("click", toggleMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isOpen) toggleMenu();
    });
  });
</script>
