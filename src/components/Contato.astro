---
const whatsappLink = "https://wa.me/5531991979373?text=Olá%2C%20vim%20pelo%20site%20e%20gostaria%20de%20falar%20com%20o%20Dr.%20Carlos%20Galvão.";
---

<section id="contato" class="py-24 bg-bg relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      
      <!-- Contact Info -->
      <div class="fade-up">
        <div class="inline-block px-4 py-1.5 rounded-full border border-gold/30 bg-gold/5 text-gold text-sm font-medium mb-6">
          <span class="animate-pulse mr-2">●</span> Plantão 24h para urgências
        </div>
        
        <h2 class="font-playfair text-4xl sm:text-5xl font-bold text-white mb-10">
          Estamos prontos para te <span class="text-gold italic">ouvir</span>
        </h2>

        <div class="space-y-8 mb-12">
          
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="flex items-start gap-4 group">
            <div class="w-10 h-10 rounded-full bg-bg-card border border-gold/30 flex items-center justify-center text-gold group-hover:bg-gold group-hover:text-bg transition-colors flex-shrink-0">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.487-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            </div>
            <div>
              <p class="text-white font-medium group-hover:text-gold transition-colors">WhatsApp 24h</p>
              <p class="text-gray-400 text-sm">(31) 99746-8554</p>
            </div>
          </a>

          <a href="https://instagram.com/carlosgalvao.adv" target="_blank" rel="noopener noreferrer" class="flex items-start gap-4 group">
            <div class="w-10 h-10 rounded-full bg-bg-card border border-gold/30 flex items-center justify-center text-gold group-hover:bg-gold group-hover:text-bg transition-colors flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </div>
            <div>
              <p class="text-white font-medium group-hover:text-gold transition-colors">Instagram</p>
              <p class="text-gray-400 text-sm">@carlosgalvao.adv</p>
            </div>
          </a>

          <a href="mailto:contato@carlosgalvaoadv.com.br" class="flex items-start gap-4 group">
            <div class="w-10 h-10 rounded-full bg-bg-card border border-gold/30 flex items-center justify-center text-gold group-hover:bg-gold group-hover:text-bg transition-colors flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div>
              <p class="text-white font-medium group-hover:text-gold transition-colors">E-mail</p>
              <p class="text-gray-400 text-sm break-all">contato@carlosgalvaoadv.com.br</p>
            </div>
          </a>

          <div class="flex items-start gap-4 group">
            <div class="w-10 h-10 rounded-full bg-bg-card border border-gold/30 flex items-center justify-center text-gold flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div>
              <p class="text-white font-medium">Matriz</p>
              <p class="text-gray-400 text-sm">Rua dos Otoni, 742, sala 605<br>Santa Efigênia, BH/MG, CEP: 30.150-270</p>
            </div>
          </div>

          <div class="flex items-start gap-4 group">
            <div class="w-10 h-10 rounded-full bg-bg-card border border-gold/30 flex items-center justify-center text-gold flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div>
              <p class="text-white font-medium">Filial</p>
              <p class="text-gray-400 text-sm">Rua Presidente Kenedy, 710<br>Centro, Barbacena/MG, CEP: 36.200-042</p>
            </div>
          </div>

        </div>

        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-gold hover:bg-gold-light text-bg font-bold py-4 px-8 rounded transition-all duration-300 shadow-[0_0_20px_rgba(201,168,76,0.2)] hover:shadow-[0_0_30px_rgba(201,168,76,0.5)] transform hover:-translate-y-1">
          Falar pelo WhatsApp agora
        </a>
      </div>

      <!-- Map Embed -->
      <div class="fade-up delay-2 w-full h-[400px] lg:h-full min-h-[400px] rounded-lg overflow-hidden border border-white/10 group relative">
        <div class="absolute inset-0 pointer-events-none border border-gold/0 group-hover:border-gold/30 transition-colors z-10 rounded-lg"></div>
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3750.814389146197!2d-43.93043818508537!3d-19.921388486609437!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xa699ebdcfb2a25%3A0xc6c4295d2c20dd99!2sR.%20dos%20Otoni%2C%20742%20-%20Santa%20Efig%C3%AAnia%2C%20Belo%20Horizonte%20-%20MG%2C%2030150-270!5e0!3m2!1sen!2sbr!4v1680000000000!5m2!1sen!2sbr" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          class="grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all duration-500"
          title="Mapa do Escritório Matriz"
        ></iframe>
      </div>

    </div>
  </div>
</section>
